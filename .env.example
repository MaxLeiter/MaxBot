# IRC connection (secrets & server config)
IRC_HOST=irc.libera.chat
IRC_PORT=6697
IRC_TLS=true
IRC_NICK=MaxBot
IRC_USERNAME=maxbot
IRC_NICKSERV_PASSWORD=

# Claude
CLAUDE_MAX_TURNS=25

# Vercel AI Gateway (optional)
# ANTHROPIC_BASE_URL=https://ai-gateway.vercel.sh
# ANTHROPIC_AUTH_TOKEN=your-ai-gateway-api-key

# Direct Anthropic API (if not using AI Gateway)
# ANTHROPIC_API_KEY=

# Runtime settings (model, channels, authorized users) are in data/settings.json
# Edit that file or use bot commands to change them.
